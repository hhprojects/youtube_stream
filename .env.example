# Copy this file to .env.local (frontend) and/or backend/.env (Pi).
# Never commit .env or .env.local.

# ─── Frontend (Expo) ────────────────────────────────────────────────
# Only vars prefixed EXPO_PUBLIC_* are exposed to the app at build time.
# Points the app at the Pi backend. Default in code is the Tailscale IP.
#   Tailscale:  http://100.87.0.56:3001/api
#   Home LAN:   http://192.168.1.11:3001/api
EXPO_PUBLIC_API_URL=http://100.87.0.56:3001/api

# ─── Backend (Pi) ──────────────────────────────────────────────────
# Host:port that the Pi advertises in /api/download and /api/library
# responses. Must be reachable from the phone.
SERVER_URL=100.87.0.56:3001

# Listen port for the Express server.
BACKEND_PORT=3001

# Where yt-dlp writes m4a files.
DOWNLOAD_DIR=./backend/downloads

# Max total size of DOWNLOAD_DIR in bytes. Oldest files pruned above this.
# Default: 2 GiB. Set to a larger number if your Pi has more disk.
DOWNLOADS_MAX_BYTES=2147483648
